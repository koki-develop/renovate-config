{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["schedule:nonOfficeHours"],
  "rangeStrategy": "pin",
  "prConcurrentLimit": 3,
  "minimumReleaseAge": "7 days",
  "packageRules": [
    {
      "matchPackageNames": ["koki-develop/github-actions-lint"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    }
  ]
}
